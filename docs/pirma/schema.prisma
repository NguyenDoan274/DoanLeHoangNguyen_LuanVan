// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum InstructorRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum MuxStatus {
  NO_VIDEO
  PROCESSING
  READY
  ERRORED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum QuestionType {
  MULTIPLE_CHOICE
  ESSAY
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String     @id @default(uuid()) @db.Uuid
  fullName     String     @map("full_name")
  email        String     @unique
  passwordHash String     @map("password_hash")
  avatarUrl    String?    @map("avatar_url")
  role         UserRole   @default(STUDENT)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime?  @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt @map("updated_at")

  // Relations
  instructorRequests InstructorRequest[] @relation("UserRequests")
  reviewedRequests   InstructorRequest[] @relation("AdminReviews")
  courses            Course[]
  enrollments        Enrollment[]
  quizAttempts       QuizAttempt[]
  gradedAnswers      QuizAnswer[]

  @@map("users")
}

model InstructorRequest {
  id         String                  @id @default(uuid()) @db.Uuid
  userId     String                  @map("user_id") @db.Uuid
  status     InstructorRequestStatus @default(PENDING)
  reason     String?
  experience String?
  expertise  String?
  adminNote  String?                 @map("admin_note")
  reviewedBy String?                 @map("reviewed_by") @db.Uuid
  reviewedAt DateTime?               @map("reviewed_at")
  createdAt  DateTime?               @default(now()) @map("created_at")
  updatedAt  DateTime?               @updatedAt @map("updated_at")

  // Relations
  user     User  @relation("UserRequests", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("AdminReviews", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("instructor_requests")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  courses Course[]

  @@map("categories")
}

model Course {
  id               String       @id @default(uuid()) @db.Uuid
  instructorId     String       @map("instructor_id") @db.Uuid
  categoryId       String?      @map("category_id") @db.Uuid
  title            String
  slug             String       @unique
  shortDescription String?      @map("short_description")
  description      String?
  thumbnailUrl     String?      @map("thumbnail_url")
  level            CourseLevel  @default(BEGINNER)
  status           CourseStatus @default(DRAFT)
  price            Decimal      @default(0) @db.Decimal(10, 2)
  createdAt        DateTime?    @default(now()) @map("created_at")
  updatedAt        DateTime?    @updatedAt @map("updated_at")

  // Relations
  instructor User            @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  category   Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sections   CourseSection[]
  enrollments Enrollment[]
  quizzes    Quiz[]

  @@map("courses")
}

model CourseSection {
  id          String    @id @default(uuid()) @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  title       String
  description String?
  orderIndex  Int       @map("order_index")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("course_sections")
}

model Lesson {
  id            String    @id @default(uuid()) @db.Uuid
  sectionId     String    @map("section_id") @db.Uuid
  title         String
  content       String?
  orderIndex    Int       @map("order_index")
  isPreview     Boolean   @default(false) @map("is_preview")
  
  // Mux video information
  muxUploadId   String?   @map("mux_upload_id")
  muxAssetId    String?   @map("mux_asset_id")
  muxPlaybackId String?   @map("mux_playback_id")
  muxStatus     MuxStatus @default(NO_VIDEO) @map("mux_status")
  durationSec   Int?      @map("duration_sec")
  
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  // Relations
  section        CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resources      LessonResource[]
  lessonProgress LessonProgress[]
  quizzes        Quiz[]

  @@map("lessons")
}

model LessonResource {
  id        String    @id @default(uuid()) @db.Uuid
  lessonId  String    @map("lesson_id") @db.Uuid
  fileName  String    @map("file_name")
  fileUrl   String    @map("file_url")
  fileType  String?   @map("file_type")
  fileSize  BigInt?   @map("file_size")
  createdAt DateTime? @default(now()) @map("created_at")

  // Relations
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_resources")
}

model Enrollment {
  id          String           @id @default(uuid()) @db.Uuid
  studentId   String           @map("student_id") @db.Uuid
  courseId    String           @map("course_id") @db.Uuid
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime?        @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")

  // Relations
  student        User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]

  @@unique([studentId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id             String    @id @default(uuid()) @db.Uuid
  enrollmentId   String    @map("enrollment_id") @db.Uuid
  lessonId       String    @map("lesson_id") @db.Uuid
  isCompleted    Boolean   @default(false) @map("is_completed")
  watchedSeconds Int       @default(0) @map("watched_seconds")
  completedAt    DateTime? @map("completed_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}

model Quiz {
  id                String    @id @default(uuid()) @db.Uuid
  courseId          String    @map("course_id") @db.Uuid
  lessonId          String?   @map("lesson_id") @db.Uuid
  title             String
  description       String?
  timeLimitMinutes  Int?      @map("time_limit_minutes")
  passingScore      Decimal   @default(0) @map("passing_score") @db.Decimal(5, 2)
  maxAttempts       Int       @default(1) @map("max_attempts")
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  // Relations
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson       Lesson?       @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions    Question[]
  quizAttempts QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id           String       @id @default(uuid()) @db.Uuid
  quizId       String       @map("quiz_id") @db.Uuid
  questionText String       @map("question_text")
  questionType QuestionType @map("question_type")
  score        Decimal      @default(1) @db.Decimal(5, 2)
  orderIndex   Int          @map("order_index")
  createdAt    DateTime?    @default(now()) @map("created_at")
  updatedAt    DateTime?    @updatedAt @map("updated_at")

  // Relations
  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers QuizAnswer[]

  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(uuid()) @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  optionText String  @map("option_text")
  isCorrect  Boolean @default(false) @map("is_correct")
  orderIndex Int     @map("order_index")

  // Relations
  question Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuizAnswer[]

  @@map("question_options")
}

model QuizAttempt {
  id           String        @id @default(uuid()) @db.Uuid
  quizId       String        @map("quiz_id") @db.Uuid
  studentId    String        @map("student_id") @db.Uuid
  enrollmentId String        @map("enrollment_id") @db.Uuid
  status       AttemptStatus @default(IN_PROGRESS)
  totalScore   Decimal       @default(0) @map("total_score") @db.Decimal(5, 2)
  isPassed     Boolean       @default(false) @map("is_passed")
  startedAt    DateTime?     @default(now()) @map("started_at")
  submittedAt  DateTime?     @map("submitted_at")
  gradedAt     DateTime?     @map("graded_at")

  // Relations
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student    User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  answers    QuizAnswer[]

  @@map("quiz_attempts")
}

model QuizAnswer {
  id               String    @id @default(uuid()) @db.Uuid
  attemptId        String    @map("attempt_id") @db.Uuid
  questionId       String    @map("question_id") @db.Uuid
  selectedOptionId String?   @map("selected_option_id") @db.Uuid
  essayAnswer      String?   @map("essay_answer")
  score            Decimal   @default(0) @db.Decimal(5, 2)
  feedback         String?
  gradedBy         String?   @map("graded_by") @db.Uuid
  gradedAt         DateTime? @map("graded_at")
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  // Relations
  attempt        QuizAttempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)
  grader         User?           @relation(fields: [gradedBy], references: [id], onDelete: SetNull)